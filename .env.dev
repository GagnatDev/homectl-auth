# DEV-ONLY environment — never use these values in production

NODE_ENV=development
PORT=3000
POSTGRES_URL=postgres://homectl_auth:password@postgres:5432/homectl_auth
APPS_CONFIG_PATH=/app/config/apps.json

# DEV-ONLY RSA key pair (2048-bit, generated for local dev)
RS256_PRIVATE_KEY_
RS256_PUBLIC_KEY_

# DEV-ONLY client secret for local-app (plaintext: "dev-secret")
LOCAL_APP_CLIENT_SECRET=$2a$12$zz8jZf2s5CRngr8v2HYxqO91eVGB/Q94BMomQt4G6Qpmp1a3rSKJO

# GitHub OAuth admin login — create a dev OAuth App with callback
# http://localhost:3000/admin/github/callback and fill these in.
GITHUB_ADMIN_CLIENT_ID=
GITHUB_ADMIN_CLIENT_SECRET=
GITHUB_ADMIN_USER_IDS=
