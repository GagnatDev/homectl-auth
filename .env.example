# ── Server ────────────────────────────────────────────────────────────────────

# Node environment — "production" | "development" | "test"
NODE_ENV=development

# Port the Express server listens on
PORT=3000

# PostgreSQL connection string
DATABASE_URL=postgres://homectl_auth:password@localhost:5432/homectl_auth

# RS256 key pair — base64-encoded PEM (no line breaks)
# Generate private: openssl genrsa 2048 | base64 -w0
# Generate public:  openssl rsa -in key.pem -pubout | base64 -w0
RS256_PRIVATE_KEY_PEM=
RS256_PUBLIC_KEY_PEM=

# Path to apps.json config (defaults to ./apps.json)
# APPS_CONFIG_PATH=/app/apps.json

# ── GitHub OAuth admin login ─────────────────────────────────────────────────
# OAuth App credentials (GitHub → Settings → Developer settings → OAuth Apps).
# Callback URL: https://auth.homectl.no/admin/github/callback
#               (http://localhost:3000/admin/github/callback for local dev)
GITHUB_ADMIN_CLIENT_ID=
GITHUB_ADMIN_CLIENT_SECRET=
# Comma-separated GitHub numeric user IDs allowed admin access.
# Find yours: curl https://api.github.com/users/<username> | grep '"id"'
GITHUB_ADMIN_USER_IDS=

# ── Per-app client secret hashes ─────────────────────────────────────────────
# One variable per registered app, named by clientSecretEnv in apps.json.
# Value must be a bcrypt hash (cost 12) of the raw client secret.
# Generate: node -e "require('bcryptjs').hash('raw',12).then(console.log)"

AIVO_CLIENT_SECRET=$2b$12$REPLACE_WITH_REAL_HASH
