<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin — Generate Invite</title>
  <style>
    body { font-family: system-ui, sans-serif; margin: 2rem; background: #f5f5f5; }
    .card { background: #fff; border-radius: 8px; box-shadow: 0 1px 4px rgba(0,0,0,.1); padding: 1.5rem; max-width: 500px; }
    h1 { margin-bottom: 1.5rem; font-size: 1.25rem; }
    label { display: block; font-size: .875rem; font-weight: 500; margin-bottom: .25rem; }
    input[type="email"], select { width: 100%; padding: .5rem .75rem; border: 1px solid #ccc; border-radius: 4px; font-size: .875rem; margin-bottom: 1rem; }
    button { padding: .5rem 1.25rem; background: #16a34a; color: #fff; border: none; border-radius: 4px; cursor: pointer; font-size: .875rem; }
    button:hover { background: #15803d; }
    .result { margin-top: 1rem; padding: .75rem 1rem; background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 4px; font-size: .875rem; word-break: break-all; }
    .back { color: #2563eb; text-decoration: none; font-size: .875rem; }
  </style>
</head>
<body>
  <a href="/admin" class="back">← Back to users</a>
  <div class="card" style="margin-top:1rem">
    <h1>Generate Invite</h1>

    <% if (result) { %>
    <div class="result">
      <strong>Invite link:</strong><br>
      /invite?token=<%= result.token %>
    </div>
    <% } %>

    <form method="POST" action="/admin/api/invites">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" required>

      <label for="appId">App</label>
      <select id="appId" name="appGrants[0][appId]" onchange="updateRoles(this.value)">
        <% for (const app of apps) { %>
          <option value="<%= app.id %>"><%= app.name %></option>
        <% } %>
      </select>

      <label for="role">Role</label>
      <select id="role" name="appGrants[0][role]">
        <% if (apps.length > 0) { %>
          <% for (const r of apps[0].roles) { %>
            <option value="<%= r.name %>"><%= r.name %></option>
          <% } %>
        <% } %>
      </select>

      <script>
        const appRoles = <%- JSON.stringify(Object.fromEntries(apps.map(a => [a.id, a.roles.map(r => r.name)]))) %>;
        function updateRoles(appId) {
          const sel = document.getElementById('role');
          sel.innerHTML = (appRoles[appId] || []).map(r => `<option value="${r}">${r}</option>`).join('');
        }
      </script>

      <button type="submit">Generate Invite Link</button>
    </form>
  </div>
</body>
</html>
