<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Error</title>
  <style>
    body { font-family: system-ui, sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh; background: #f5f5f5; }
    .card { background: #fff; border-radius: 8px; padding: 2rem; box-shadow: 0 1px 4px rgba(0,0,0,.1); text-align: center; }
    h1 { color: #dc2626; }
    p  { color: #666; margin-top: .5rem; }
  </style>
</head>
<body>
  <div class="card">
    <h1>Access Denied</h1>
    <p><%= message %></p>
    <p><a href="/">Go home</a></p>
  </div>
</body>
</html>
