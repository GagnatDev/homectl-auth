<table id="access-table">
  <thead><tr><th>App</th><th>Role</th><th></th></tr></thead>
  <tbody>
    <% for (const a of access) { %>
    <tr id="access-<%= a.appId %>">
      <td><%= a.appId %></td>
      <td><%= a.role %></td>
      <td>
        <button
          hx-delete="/admin/api/users/<%= user.id %>/access/<%= a.appId %>"
          hx-target="#access-<%= a.appId %>"
          hx-swap="outerHTML"
          hx-confirm="Remove <%= a.appId %> access?">
          Revoke
        </button>
      </td>
    </tr>
    <% } %>
  </tbody>
</table>
