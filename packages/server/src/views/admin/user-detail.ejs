<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin — <%= user.email %></title>
  <script src="https://unpkg.com/htmx.org@1.9.12"></script>
  <style>
    body { font-family: system-ui, sans-serif; margin: 2rem; background: #f5f5f5; }
    h1 { margin-bottom: .5rem; }
    .meta { color: #666; font-size: .875rem; margin-bottom: 1.5rem; }
    h2 { font-size: 1rem; margin: 1.5rem 0 .75rem; }
    table { width: 100%; border-collapse: collapse; background: #fff; border-radius: 8px; box-shadow: 0 1px 4px rgba(0,0,0,.1); }
    th, td { padding: .625rem 1rem; text-align: left; border-bottom: 1px solid #eee; font-size: .875rem; }
    th { background: #f9fafb; font-weight: 600; }
    button { padding: .25rem .75rem; border: 1px solid #dc2626; color: #dc2626; background: #fff; border-radius: 4px; cursor: pointer; font-size: .875rem; }
    button:hover { background: #fef2f2; }
    .back { color: #2563eb; text-decoration: none; font-size: .875rem; }
    form.grant { display: flex; gap: .5rem; margin-top: .75rem; }
    form.grant select, form.grant input { padding: .375rem .5rem; border: 1px solid #ccc; border-radius: 4px; font-size: .875rem; }
    form.grant button { border-color: #2563eb; color: #2563eb; }
    form.grant button:hover { background: #eff6ff; }
  </style>
</head>
<body>
  <a href="/admin" class="back">← Back to users</a>
  <h1><%= user.email %></h1>
  <p class="meta">
    Username: <strong><%= user.username %></strong> ·
    Admin: <strong><%= user.isAdmin ? 'Yes' : 'No' %></strong> ·
    Last login: <strong><%= user.lastLoginAt ? new Date(user.lastLoginAt).toLocaleString() : '—' %></strong>
  </p>

  <h2>App Access</h2>
  <%- include('_access-table', { access, user }) %>

  <form class="grant"
    hx-post="/admin/api/users/<%= user.id %>/access"
    hx-target="#access-table"
    hx-swap="outerHTML"
  >
    <select name="appId">
      <% for (const app of apps) { %>
        <option value="<%= app.id %>"><%= app.name %></option>
      <% } %>
    </select>
    <select name="role" id="role-select">
      <% if (apps.length > 0) { %>
        <% for (const r of apps[0].roles) { %>
          <option value="<%= r.name %>"><%= r.name %></option>
        <% } %>
      <% } %>
    </select>
    <button type="submit">Grant Access</button>
  </form>

  <h2>Actions</h2>
  <button
    hx-post="/admin/api/users/<%= user.id %>/password-reset"
    hx-target="#reset-result"
    hx-swap="innerHTML">
    Generate password reset link
  </button>
  <div id="reset-result" style="margin-top:.5rem;font-size:.875rem;color:#166534;"></div>
</body>
</html>
