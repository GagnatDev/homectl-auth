{
  "name": "@gagnatdev/homectl-auth-client",
  "version": "0.2.0",
  "description": "Client package for homectl-auth — server-side Express middleware and browser-side token helper",
  "exports": {
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "require": "./dist/browser.js",
      "default": "./dist/browser.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "peerDependencies": {
    "express": "^4.x"
  },
  "dependencies": {
    "jose": "^5.2.4",
    "jwks-rsa": "^3.1.0",
    "cookie": "^0.6.0"
  },
  "devDependencies": {
    "@types/cookie": "^0.6.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "@types/supertest": "^6.0.2",
    "cookie-parser": "^1.4.6",
    "express": "^4.19.2",
    "supertest": "^7.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.5.3"
  }
}
