{
  "name": "@gagnatdev/homectl-auth-client",
  "version": "0.1.0",
  "description": "Client package for homectl-auth — server-side Express middleware and browser-side token helper",
  "exports": {
    "./server": {
      "require": "./dist/server.js",
      "types": "./dist/server.d.ts"
    },
    "./browser": {
      "require": "./dist/browser.js",
      "types": "./dist/browser.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "express": "^4.x"
  },
  "dependencies": {
    "jose": "^5.2.4",
    "jwks-rsa": "^3.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "typescript": "^5.4.5",
    "vitest": "^1.5.3"
  }
}
